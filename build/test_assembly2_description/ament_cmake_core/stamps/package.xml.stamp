<?xml version="1.0"?>
<package format="3">
  <name>test_assembly2_description</name>
  <version>0.1.0</version>
  <description>ROS2 description package converted from Fusion360 assembly for the cooperative parking robot visual model.</description>

  <maintainer email="todo@example.com">shiha</maintainer>
  <license>MIT</license>

  <buildtool_depend>ament_cmake</buildtool_depend>

  <exec_depend>xacro</exec_depend>
  <exec_depend>robot_state_publisher</exec_depend>
  <exec_depend>joint_state_publisher</exec_depend>
  <exec_depend>joint_state_publisher_gui</exec_depend>
  <exec_depend>rviz2</exec_depend>

  <!-- Optional: only needed when using launch/spawn_two_robots_gz.launch.py -->
  <exec_depend>ros_gz_sim</exec_depend>

  <export>
    <build_type>ament_cmake</build_type>
  </export>
</package>
